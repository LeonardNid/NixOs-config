#!/usr/bin/env bash
# Bootstrap-Skript für frisches NixOS-Install auf dem Laptop
# Ausführen mit: bash <(curl -sL https://raw.githubusercontent.com/LeonardNid/NixOs-config/main/scripts/bootstrap.sh)
